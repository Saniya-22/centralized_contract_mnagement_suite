OPENAI_API_KEY=sk-your-openai-api-key-here
MODEL_NAME=gpt-4o-mini
SYNTHESIZER_MODEL=gpt-4o

# PostgreSQL (local)
PG_HOST=localhost
PG_PORT=5432
PG_DB=daedalus
PG_USER=your_db_username
PG_PASSWORD=your_db_password
PG_DENSE_TABLE=embeddings_dense
PG_SPARSE_TABLE=embeddings_sparse
REGULATIONS_NAMESPACE=public-regulations
DATABASE_URL=postgresql://your_db_username:your_db_password@localhost:5432/daedalus
JWT_SECRET_KEY=your-secure-jwt-secret-key-here
RERANKER_ENABLED=True
ADMIN_API_KEY=your-secure-admin-api-key
COOKIE_SECRET=your-secure-cookie-secret

# Optional: Sovereign-AI guardrail layer
SOVEREIGN_GUARD_ENABLED=false
SOVEREIGN_GUARD_BASE_URL=http://localhost:8001
SOVEREIGN_GUARD_DETECT_PATH=/detect
SOVEREIGN_GUARD_TIMEOUT_SECONDS=3.0
SOVEREIGN_GUARD_FAIL_OPEN=true
SOVEREIGN_GUARD_BLOCK_MODE=soft
# SOVEREIGN_GUARD_AUTH_TOKEN=your_sovereign_service_jwt
