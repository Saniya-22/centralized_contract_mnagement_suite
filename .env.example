OPENAI_API_KEY=sk-your-openai-api-key-here
MODEL_NAME=gpt-4o
CORE_BASE_URL=https://staging-api.govgig.us

# PostgreSQL (local)
PG_HOST=localhost
PG_PORT=5432
PG_DB=daedalus
PG_USER=your_db_username
PG_PASSWORD=your_db_password
PG_DENSE_TABLE=embeddings_dense
PG_SPARSE_TABLE=embeddings_sparse
REGULATIONS_NAMESPACE=public-regulations
DATABASE_URL=postgresql://your_db_username:your_db_password@localhost:5432/daedalus
JWT_SECRET_KEY=your-secure-jwt-secret-key-here
RERANKER_ENABLED=False
PILOT_SAFE_MODE=True
PILOT_MIN_DOCS=3
PILOT_MIN_TOP_SCORE=0.35
PILOT_MIN_AVG_SCORE=0.20
